# Copy this file to .env and fill in your values
# Railway: set these in the Variables tab instead

# Required
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789

# Bot identity
BOT_USERNAME=YourBotUsername

# Group & channel IDs (negative numbers)
GROUP_ID=-1001234567890
CHANNEL_ID=-1001234567890

# Test mode (true/false)
TEST_MODE=false
TEST_GROUP_ID=-100
TEST_CHANNEL_ID=-1001234567890

# Optional overrides
AUTO_ABORT=21600
GROUP_STATS=true
MILESTONES=50,100,200,500,1000
